---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const seances = await getCollection('conseil');
  return seances.map((seance) => ({
    params: { slug: seance.slug },
    props: { seance },
  }));
}

const { seance } = Astro.props;
const { Content } = await seance.render();

const fmtDate = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout title={`${seance.data.title} — Conseil municipal de Kienheim`} description={seance.data.title}>
  <Navbar />
  <main id="main-content" class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">

    <a href="/mairie#comptes-rendus" class="inline-flex items-center gap-2 text-sm font-semibold mb-8 link-primary" onclick="if(history.length > 1){ history.back(); return false; }">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Retour
    </a>

    <div class="flex items-center gap-3 mb-4">
      <span class="badge-secondary">Compte-rendu</span>
      <time class="text-sm" style="color: var(--c-muted);" datetime={seance.data.date.toISOString()}>
        {fmtDate(seance.data.date)}
      </time>
    </div>

    <h1 class="text-3xl sm:text-4xl font-black mb-6 leading-tight" style="color: var(--c-primary);">
      {seance.data.title}
    </h1>

    {seance.data.document_pdf && (
      <a
        href={seance.data.document_pdf}
        class="btn-accent mb-8 inline-flex"
        target="_blank"
        rel="noopener"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Télécharger le compte-rendu PDF
      </a>
    )}

    <div class="prose max-w-none" style="color: var(--c-fg);">
      <Content />
    </div>

  </main>
  <Footer />
</Layout>

<style>
  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--c-primary);
    margin: 2rem 0 0.75rem;
  }
  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--c-primary);
    margin: 1.5rem 0 0.5rem;
  }
  .prose :global(p) {
    margin: 0 0 1rem;
    line-height: 1.75;
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1rem;
  }
  .prose :global(li) {
    margin-bottom: 0.375rem;
    line-height: 1.6;
  }
  .prose :global(strong) {
    font-weight: 700;
    color: var(--c-fg);
  }
  .prose :global(a) {
    color: var(--c-primary);
    font-weight: 600;
    text-decoration: underline;
  }
</style>
