---
// Page d'administration Decap CMS — accessible sur /admin
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Administration — Mairie de Kienheim</title>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <!-- DOIT être synchrone et AVANT le script Decap -->
    <script is:inline>
      window.CMS_MANUAL_INIT = true;
    </script>
  </head>
  <body>
    <script is:inline src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
    <script is:inline>
      CMS.init({
        config: {
          backend: { name: 'git-gateway', branch: 'main' },
          media_folder:  'public/images/uploads',
          public_folder: '/images/uploads',
          locale: 'fr',
          collections: [
            {
              name: 'actualites', label: 'Actualités', label_singular: 'Actualité',
              folder: 'src/content/actualites', create: true,
              slug: '{{year}}-{{month}}-{{slug}}',
              fields: [
                { name: 'title',       label: 'Titre',                widget: 'string',   required: true },
                { name: 'date',        label: 'Date de publication',   widget: 'datetime', required: true,
                  date_format: 'DD/MM/YYYY', time_format: 'HH:mm', format: 'YYYY-MM-DDTHH:mm:ssZ' },
                { name: 'description', label: 'Résumé',               widget: 'text',     required: true,
                  hint: "Court résumé affiché sur la carte (200 car. max)" },
                { name: 'categorie',   label: 'Catégorie',            widget: 'select',   required: true,
                  options: ['Information', 'Événement', 'Travaux', 'Associations'], default: 'Information' },
                { name: 'image',       label: "Image à la une",       widget: 'image',    required: false,
                  media_folder: '/public/images/actualites', public_folder: '/images/actualites' },
                { name: 'body',        label: "Contenu de l'article", widget: 'markdown', required: false },
              ],
            },
            {
              name: 'evenements', label: 'Événements', label_singular: 'Événement',
              folder: 'src/content/evenements', create: true,
              slug: '{{year}}-{{month}}-{{slug}}',
              fields: [
                { name: 'title',       label: "Nom de l'événement",  widget: 'string',   required: true },
                { name: 'date_debut',  label: 'Date de début',       widget: 'datetime', required: true,
                  date_format: 'DD/MM/YYYY', time_format: 'HH:mm', format: 'YYYY-MM-DDTHH:mm:ssZ' },
                { name: 'date_fin',    label: 'Date de fin',         widget: 'datetime', required: false,
                  date_format: 'DD/MM/YYYY', time_format: 'HH:mm', format: 'YYYY-MM-DDTHH:mm:ssZ',
                  hint: "Laisser vide si événement sur une seule journée" },
                { name: 'lieu',        label: 'Lieu',                widget: 'string',   required: false },
                { name: 'description', label: 'Description courte',  widget: 'text',     required: true },
                { name: 'image',       label: 'Affiche / visuel',    widget: 'image',    required: false,
                  media_folder: '/public/images/actualites', public_folder: '/images/actualites' },
                { name: 'body',        label: 'Détails',             widget: 'markdown', required: false },
              ],
            },
            {
              name: 'conseil', label: 'Conseil municipal', label_singular: 'Séance du conseil',
              folder: 'src/content/conseil', create: true,
              slug: '{{year}}-{{month}}-{{slug}}',
              fields: [
                { name: 'title',        label: 'Titre de la séance',     widget: 'string',   required: true },
                { name: 'date',         label: 'Date du conseil',        widget: 'datetime', required: true,
                  date_format: 'DD/MM/YYYY', time_format: 'HH:mm', format: 'YYYY-MM-DDTHH:mm:ssZ' },
                { name: 'document_pdf', label: 'PDF du compte-rendu',    widget: 'file',     required: false,
                  media_folder: '/public/documents/conseil', public_folder: '/documents/conseil' },
                { name: 'body',         label: 'Résumé / ordre du jour', widget: 'markdown', required: false },
              ],
            },
            {
              name: 'bulletins', label: 'KienheiMAG', label_singular: 'Bulletin',
              folder: 'src/content/bulletins', create: true,
              slug: 'bulletin-{{fields.numero}}',
              fields: [
                { name: 'title',            label: 'Titre du bulletin',       widget: 'string',   required: true },
                { name: 'numero',           label: 'Numéro',                  widget: 'number',   required: true, value_type: 'int', min: 1 },
                { name: 'date',             label: 'Date de parution',        widget: 'datetime', required: true,
                  date_format: 'DD/MM/YYYY', time_format: false, format: 'YYYY-MM-DD' },
                { name: 'fichier_pdf',      label: 'Fichier PDF du bulletin', widget: 'file',     required: true,
                  media_folder: '/public/documents/bulletins', public_folder: '/documents/bulletins' },
                { name: 'image_couverture', label: 'Image de couverture',     widget: 'image',    required: false },
                { name: 'body',             label: 'Erratum / notes',         widget: 'markdown', required: false },
              ],
            },
            {
              name: 'elus', label: 'Élus', label_singular: 'Élu·e',
              folder: 'src/content/elus', create: true,
              slug: '{{fields.ordre}}-{{slug}}',
              sortable_fields: ['ordre', 'nom'],
              fields: [
                { name: 'nom',        label: 'Nom complet',             widget: 'string',   required: true,
                  hint: 'Prénom NOM (ex : Olivier COURSON)' },
                { name: 'fonction',   label: 'Fonction',                widget: 'select',   required: true,
                  options: ['Maire', '1er Adjoint', '2ème Adjoint', '3ème Adjoint', 'Conseiller municipal', 'Conseillère municipale'] },
                { name: 'ordre',      label: "Ordre d'affichage",       widget: 'number',   required: true, value_type: 'int', min: 1 },
                { name: 'commission', label: 'Commission / délégation', widget: 'string',   required: false },
                { name: 'photo',      label: 'Photo',                   widget: 'image',    required: false,
                  media_folder: '/public/images/elus', public_folder: '/images/elus' },
              ],
            },
            {
              name: 'pages', label: 'Pages du site', label_singular: 'Page',
              folder: 'src/content/pages', create: false,
              fields: [
                { name: 'title', label: 'Titre de la page', widget: 'string',   required: true },
                { name: 'body',  label: 'Contenu',          widget: 'markdown', required: false },
              ],
            },
          ],
        },
      });
    </script>
  </body>
</html>
