---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('actualites');
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const fmtDate = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout title={`${article.data.title} — Mairie de Kienheim`} description={article.data.description}>
  <main id="main-content" class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">

    <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold mb-8 link-primary">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Retour à l'accueil
    </a>

    <div class="flex items-center gap-3 mb-4">
      <span class="badge-secondary">{article.data.categorie}</span>
      <time class="text-sm" style="color: var(--c-muted);" datetime={article.data.date.toISOString()}>
        {fmtDate(article.data.date)}
      </time>
    </div>

    {article.data.image && (
      <img
        src={article.data.image}
        alt=""
        class="w-full rounded-2xl mb-8 object-cover"
        style="max-height: 400px;"
      />
    )}

    <h1 class="text-3xl sm:text-4xl font-black mb-6 leading-tight" style="color: var(--c-primary);">
      {article.data.title}
    </h1>

    <p class="text-lg mb-8 leading-relaxed" style="color: var(--c-muted);">
      {article.data.description}
    </p>

    <div class="prose prose-blue max-w-none" style="color: var(--c-fg);">
      <Content />
    </div>

  </main>
</Layout>

<style>
  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--c-primary);
    margin: 2rem 0 0.75rem;
  }
  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--c-primary);
    margin: 1.5rem 0 0.5rem;
  }
  .prose :global(p) {
    margin: 0 0 1rem;
    line-height: 1.75;
  }
  .prose :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin: 0 0 1rem;
  }
  .prose :global(li) {
    margin-bottom: 0.375rem;
    line-height: 1.6;
  }
  .prose :global(strong) {
    font-weight: 700;
    color: var(--c-fg);
  }
  .prose :global(a) {
    color: var(--c-primary);
    font-weight: 600;
    text-decoration: underline;
  }
</style>
