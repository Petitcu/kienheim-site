---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const evenements = await getCollection('evenements');
  return evenements.map((evt) => ({
    params: { slug: evt.slug },
    props: { evt },
  }));
}

const { evt } = Astro.props;
const { Content } = await evt.render();

const fmtDate = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
const fmtHeure = (d: Date) =>
  d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
---

<Layout title={`${evt.data.title} — Mairie de Kienheim`} description={evt.data.description}>
  <main id="main-content" class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">

    <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold mb-8 link-primary">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Retour à l'accueil
    </a>

    <div class="flex items-center gap-2 mb-4">
      <svg class="w-5 h-5" style="color: var(--c-secondary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <span class="text-sm font-semibold" style="color: var(--c-secondary);">Événement</span>
    </div>

    {evt.data.image && (
      <img
        src={evt.data.image}
        alt=""
        class="w-full rounded-2xl mb-8 object-cover"
        style="max-height: 400px;"
      />
    )}

    <h1 class="text-3xl sm:text-4xl font-black mb-4 leading-tight" style="color: var(--c-primary);">
      {evt.data.title}
    </h1>

    <!-- Dates et lieu -->
    <div class="rounded-xl p-4 mb-8 flex flex-wrap gap-4" style="background: var(--c-border);">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider mb-0.5" style="color: var(--c-muted);">Date</p>
        <p class="text-sm font-semibold" style="color: var(--c-fg);">
          {fmtDate(evt.data.date_debut)}
          {evt.data.date_fin && evt.data.date_fin.toDateString() !== evt.data.date_debut.toDateString() && (
            <> → {fmtDate(evt.data.date_fin)}</>
          )}
        </p>
        <p class="text-xs" style="color: var(--c-muted);">
          {fmtHeure(evt.data.date_debut)}
          {evt.data.date_fin && <> – {fmtHeure(evt.data.date_fin)}</>}
        </p>
      </div>
      {evt.data.lieu && (
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider mb-0.5" style="color: var(--c-muted);">Lieu</p>
          <p class="text-sm font-semibold" style="color: var(--c-fg);">{evt.data.lieu}</p>
        </div>
      )}
    </div>

    <p class="text-lg mb-8 leading-relaxed" style="color: var(--c-muted);">
      {evt.data.description}
    </p>

    <div class="prose max-w-none" style="color: var(--c-fg);">
      <Content />
    </div>

  </main>
</Layout>

<style>
  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--c-primary);
    margin: 2rem 0 0.75rem;
  }
  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--c-primary);
    margin: 1.5rem 0 0.5rem;
  }
  .prose :global(p) {
    margin: 0 0 1rem;
    line-height: 1.75;
  }
  .prose :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin: 0 0 1rem;
  }
  .prose :global(li) {
    margin-bottom: 0.375rem;
    line-height: 1.6;
  }
  .prose :global(strong) {
    font-weight: 700;
    color: var(--c-fg);
  }
</style>
