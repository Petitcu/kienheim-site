---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import TabbedContent from '../../components/TabbedContent.astro';
import PostCard from '../../components/PostCard.astro';
import EventCard from '../../components/EventCard.astro';

// Collections
const allActualites = await getCollection('actualites');
allActualites.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allEvenements = await getCollection('evenements');
allEvenements.sort((a, b) => a.data.date_debut.getTime() - b.data.date_debut.getTime());

const allBulletins = await getCollection('bulletins');
allBulletins.sort((a, b) => b.data.numero - a.data.numero);

// Filtres par catégorie
const kienheimFlash = allActualites.filter((a) =>
  ['Kienheim Flash', 'Information'].includes(a.data.categorie ?? '')
);
const vieAsso = allActualites.filter((a) =>
  a.data.categorie === 'Vie associative'
);
const vieEco = allActualites.filter((a) =>
  a.data.categorie === 'Vie économique'
);
const viePratique = allActualites.filter((a) =>
  a.data.categorie === 'Vie pratique'
);

const tabs = [
  { id: 'agenda',    label: 'Agenda',          icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
  { id: 'flash',     label: "Kienheim'Flash",   icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
  { id: 'mag',       label: 'KienheiMAG',       icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' },
  { id: 'pratique',  label: 'Vie pratique',     icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { id: 'asso',      label: 'Vie associative',  icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
  { id: 'eco',       label: 'Vie économique',   icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z' },
];

const fmtDay = (d: Date) => d.toLocaleDateString('fr-FR', { day: 'numeric' });
const fmtMonth = (d: Date) => d.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' });
---

<Layout title="Vivre à Kienheim — Actualités, Agenda & KienheiMAG" description="Agenda des événements, actualités, KienheiMAG, vie associative et économique de Kienheim.">
  <Navbar />
  <main id="main-content" class="pt-16">

    <!-- Hero -->
    <div class="py-12 px-4 sm:px-6 lg:px-8" style="background: var(--c-primary);">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center gap-3 mb-2">
          <a href="/" class="text-white/70 hover:text-white text-sm transition-colors">Accueil</a>
          <span class="text-white/40">/</span>
          <span class="text-white text-sm font-medium">Vivre à Kienheim</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-black text-white">Vivre à Kienheim</h1>
        <p class="mt-2 text-white/80 max-w-xl">
          Agenda, actualités, KienheiMAG et vie locale — tout ce qui se passe dans votre commune.
        </p>
      </div>
    </div>

    <!-- Onglets -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <TabbedContent tabs={tabs} id="vivre" defaultTab="agenda">

        <!-- ── AGENDA ── -->
        <div data-panel="agenda">
          <div class="mb-8">
            <h2 class="text-2xl font-black section-title mb-2">Agenda des événements</h2>
            <p class="text-sm" style="color: var(--c-muted);">Prochains événements à Kienheim et dans le canton.</p>
          </div>

          {allEvenements.length > 0 ? (
            <div class="space-y-3">
              {allEvenements.map((evt) => (
                <EventCard
                  title={evt.data.title}
                  date_debut={evt.data.date_debut}
                  date_fin={evt.data.date_fin}
                  lieu={evt.data.lieu}
                  description={evt.data.description}
                  slug={evt.slug}
                />
              ))}
            </div>
          ) : (
            <div class="text-center py-16 rounded-2xl" style="background: var(--c-border); color: var(--c-muted);">
              <svg class="w-10 h-10 mx-auto mb-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p class="text-sm">Aucun événement à venir pour le moment.</p>
            </div>
          )}
        </div>

        <!-- ── KIENHEIM'FLASH ── -->
        <div data-panel="flash">
          <div class="mb-8">
            <h2 class="text-2xl font-black section-title mb-2">Kienheim'Flash</h2>
            <p class="text-sm" style="color: var(--c-muted);">Les actualités de la commune — informations, événements et vie locale.</p>
          </div>

          {kienheimFlash.length > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {kienheimFlash.map((article) => (
                <PostCard
                  title={article.data.title}
                  date={article.data.date}
                  description={article.data.description ?? ''}
                  slug={article.slug}
                  image={article.data.image}
                  categorie={article.data.categorie}
                />
              ))}
            </div>
          ) : (
            <p class="text-sm py-8 text-center" style="color: var(--c-muted);">Aucune actualité disponible.</p>
          )}
        </div>

        <!-- ── KIENHEIMIAG ── -->
        <div data-panel="mag">
          <div class="mb-8">
            <h2 class="text-2xl font-black section-title mb-2">KienheiMAG</h2>
            <p class="text-sm" style="color: var(--c-muted);">Le bulletin municipal trimestriel de Kienheim — à lire et télécharger.</p>
          </div>

          {allBulletins.length > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
              {allBulletins.map((bulletin) => (
                <article
                  class="bento-card bg-white dark:bg-kienheim-dark-surface flex flex-col shadow-sm reveal"
                  style="border: 1px solid var(--c-border);"
                  aria-labelledby={`bulletin-${bulletin.slug}`}
                >
                  <!-- Couverture ou placeholder -->
                  <div class="rounded-t-[1.25rem] overflow-hidden">
                    {bulletin.data.image_couverture ? (
                      <img
                        src={bulletin.data.image_couverture}
                        alt={`Couverture ${bulletin.data.title}`}
                        loading="lazy"
                        class="w-full h-40 object-cover"
                      />
                    ) : (
                      <div
                        class="w-full h-40 flex flex-col items-center justify-center"
                        style="background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-secondary) 100%);"
                        aria-hidden="true"
                      >
                        <span class="text-4xl font-black text-white/90">N°{bulletin.data.numero}</span>
                        <span class="text-sm text-white/60 mt-1">KienheiMAG</span>
                      </div>
                    )}
                  </div>

                  <div class="p-4 flex flex-col flex-1">
                    <p class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: var(--c-muted);">
                      N°{bulletin.data.numero} · {bulletin.data.date.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}
                    </p>
                    <h3
                      id={`bulletin-${bulletin.slug}`}
                      class="text-sm font-bold leading-snug flex-1"
                      style="color: var(--c-fg);"
                    >
                      {bulletin.data.title}
                    </h3>
                    <a
                      href={bulletin.data.fichier_pdf}
                      class="btn-accent mt-4 self-start"
                      target="_blank"
                      rel="noopener"
                      aria-label={`Télécharger ${bulletin.data.title} (PDF)`}
                    >
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      Télécharger
                    </a>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <p class="text-sm py-8 text-center" style="color: var(--c-muted);">Aucun bulletin disponible.</p>
          )}
        </div>

        <!-- ── VIE PRATIQUE ── -->
        <div data-panel="pratique">
          <div class="mb-8">
            <h2 class="text-2xl font-black section-title mb-2">Vie pratique</h2>
            <p class="text-sm" style="color: var(--c-muted);">Informations pratiques pour les habitants de Kienheim.</p>
          </div>

          {viePratique.length > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {viePratique.map((article) => (
                <PostCard
                  title={article.data.title}
                  date={article.data.date}
                  description={article.data.description ?? ''}
                  slug={article.slug}
                  image={article.data.image}
                  categorie={article.data.categorie}
                />
              ))}
            </div>
          ) : (
            <p class="text-sm py-8 text-center" style="color: var(--c-muted);">Aucun article disponible.</p>
          )}
        </div>

        <!-- ── VIE ASSOCIATIVE ── -->
        <div data-panel="asso">
          <div class="mb-8">
            <h2 class="text-2xl font-black section-title mb-2">Vie associative</h2>
            <p class="text-sm" style="color: var(--c-muted);">Les associations actives à Kienheim et leurs actualités.</p>
          </div>

          {vieAsso.length > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {vieAsso.map((article) => (
                <PostCard
                  title={article.data.title}
                  date={article.data.date}
                  description={article.data.description ?? ''}
                  slug={article.slug}
                  image={article.data.image}
                  categorie={article.data.categorie}
                />
              ))}
            </div>
          ) : (
            <p class="text-sm py-8 text-center" style="color: var(--c-muted);">Aucun article disponible.</p>
          )}
        </div>

        <!-- ── VIE ÉCONOMIQUE ── -->
        <div data-panel="eco">
          <div class="mb-8">
            <h2 class="text-2xl font-black section-title mb-2">Vie économique</h2>
            <p class="text-sm" style="color: var(--c-muted);">Entreprises, commerces et activités économiques à Kienheim.</p>
          </div>

          {vieEco.length > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {vieEco.map((article) => (
                <PostCard
                  title={article.data.title}
                  date={article.data.date}
                  description={article.data.description ?? ''}
                  slug={article.slug}
                  image={article.data.image}
                  categorie={article.data.categorie}
                />
              ))}
            </div>
          ) : (
            <p class="text-sm py-8 text-center" style="color: var(--c-muted);">Aucun article disponible.</p>
          )}
        </div>

      </TabbedContent>
    </div>

  </main>
  <Footer />
</Layout>
