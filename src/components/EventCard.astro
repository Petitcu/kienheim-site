---
export interface Props {
  title: string;
  date_debut: Date;
  date_fin?: Date;
  lieu?: string;
  description: string;
  slug: string;
}

const { title, date_debut, date_fin, lieu, description, slug } = Astro.props;

const day = date_debut.toLocaleDateString('fr-FR', { day: 'numeric' });
const month = date_debut.toLocaleDateString('fr-FR', { month: 'short' });
const year = date_debut.getFullYear();
---

<article
  class="event-card bento-card bg-white dark:bg-kienheim-dark-surface flex gap-4 p-5 shadow-sm reveal"
  style="border: 1px solid var(--c-border);"
  aria-labelledby={`event-${slug}`}
>
  <!-- Date block -->
  <div
    class="flex-shrink-0 flex flex-col items-center justify-center w-16 h-16 rounded-xl text-white"
    style="background: var(--c-primary);"
    aria-hidden="true"
  >
    <span class="text-2xl font-black leading-none">{day}</span>
    <span class="text-xs font-semibold uppercase mt-0.5">{month}</span>
  </div>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <h3
      id={`event-${slug}`}
      class="text-sm font-bold leading-snug truncate"
      style="color: var(--c-fg);"
    >
      {title}
    </h3>

    {lieu && (
      <p class="text-xs mt-0.5 flex items-center gap-1" style="color: var(--c-muted);">
        <svg class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        {lieu}
      </p>
    )}

    <p class="text-xs mt-1.5 leading-relaxed line-clamp-2" style="color: var(--c-muted);">
      {description}
    </p>

    <a
      href={`/evenements/${slug}`}
      class="mt-2 inline-flex items-center gap-1 text-xs font-semibold link-primary"
    >
      Détails →
    </a>
  </div>
</article>
