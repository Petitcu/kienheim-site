---
const quickLinks = [
  { label: 'Accueil',             href: '/' },
  { label: 'Dernières actualités',href: '/vivre' },
  { label: 'Découvrir le village',href: '/village' },
  { label: 'Conseil municipal',   href: '/mairie#comptes-rendus' },
  { label: 'Vie pratique',        href: '/vivre' },
  { label: 'KienheiMAG',          href: '/vivre' },
];
---

<footer style="background: #1E3550; color: #D0D8E4;" class="pt-16 pb-8 px-4 sm:px-6 lg:px-8" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Pied de page — Mairie de Kienheim</h2>

  <div class="max-w-7xl mx-auto">

    <!-- 3 colonnes -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pb-12" style="border-bottom: 1px solid rgba(255,255,255,0.1);">

      <!-- Col 1 : Contact mairie -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <img
            src="/assets/images/blason.png"
            alt="Blason de Kienheim"
            class="h-10 w-auto opacity-90"
          />
          <div>
            <p class="text-white font-bold text-sm tracking-widest uppercase">Kienheim</p>
            <p class="text-xs" style="color: rgba(208,216,228,0.55);">Commune du Bas-Rhin</p>
          </div>
        </div>

        <address class="not-italic space-y-2 text-sm" style="color: rgba(208,216,228,0.75);">
          <p class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>6 rue de l'Église<br />67270 Kienheim</span>
          </p>
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+33388000000" class="hover:text-white transition-colors">03 88 XX XX XX</a>
          </p>
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:contact@kienheim.fr" class="hover:text-white transition-colors">contact@kienheim.fr</a>
          </p>
        </address>

        <div class="mt-5 text-xs" style="color: rgba(208,216,228,0.55);">
          <p class="font-medium mb-1" style="color: rgba(208,216,228,0.80);">Horaires d'ouverture</p>
          <p>Lun – Ven : 9h00 – 12h00</p>
          <p>Mercredi : 14h00 – 17h00</p>
        </div>
      </div>

      <!-- Col 2 : Liens rapides -->
      <div>
        <h3 class="text-white font-bold text-sm tracking-widest uppercase mb-5">Liens rapides</h3>
        <ul class="space-y-2.5" role="list">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm hover:text-white transition-colors flex items-center gap-2 group"
                style="color: rgba(208,216,228,0.70);"
              >
                <svg class="w-3.5 h-3.5 transition-colors" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <div class="mt-8">
          <h3 class="text-white font-bold text-sm tracking-widest uppercase mb-3">Ressources utiles</h3>
          <ul class="space-y-2" role="list">
            <li>
              <a href="https://www.service-public.gouv.fr" target="_blank" rel="noopener noreferrer" class="text-sm hover:text-white transition-colors" style="color: rgba(208,216,228,0.70);">
                service-public.fr ↗
              </a>
            </li>
            <li>
              <a href="https://www.alsace.eu" target="_blank" rel="noopener noreferrer" class="text-sm hover:text-white transition-colors" style="color: rgba(208,216,228,0.70);">
                Département du Bas-Rhin ↗
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Col 3 : ComCom Kochersberg -->
      <div>
        <h3 class="text-white font-bold text-sm tracking-widest uppercase mb-5">Intercommunalité</h3>

        <div class="rounded-xl p-6 text-center mb-4" style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1);">
          <p class="text-xs uppercase tracking-wider mb-1" style="color: rgba(208,216,228,0.50);">Communauté de Communes</p>
          <p class="text-white font-bold text-base">Kochersberg–<br />Ackerland</p>
          <p class="text-xs mt-1" style="color: rgba(208,216,228,0.50);">Bas-Rhin · 67370</p>
          <a
            href="https://www.kochersberg.fr"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 inline-block text-xs font-semibold hover:underline"
            style="color: #C9A84C;"
          >
            www.kochersberg.fr ↗
          </a>
        </div>

        <p class="text-xs leading-relaxed" style="color: rgba(208,216,228,0.55);">
          La commune de Kienheim est membre de la Communauté de Communes du Kochersberg–Ackerland, regroupant 45 communes et environ 35 000 habitants au nord-ouest de Strasbourg.
        </p>
      </div>
    </div>

    <!-- Bas de footer -->
    <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs" style="color: rgba(208,216,228,0.40);">
      <p>© 2026 Commune de Kienheim — Tous droits réservés</p>
      <nav aria-label="Liens légaux">
        <ul class="flex flex-wrap gap-4 justify-center" role="list">
          <li><a href="/mentions-legales" class="hover:text-white transition-colors">Mentions légales</a></li>
          <li><a href="/confidentialite" class="hover:text-white transition-colors">Politique de confidentialité</a></li>
          <li><a href="/confidentialite" class="hover:text-white transition-colors">RGPD</a></li>
          <li><a href="/accessibilite" class="hover:text-white transition-colors">Accessibilité</a></li>
        </ul>
      </nav>
    </div>

  </div>
</footer>
