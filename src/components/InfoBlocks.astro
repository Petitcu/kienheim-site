---
export interface InfoBlock {
  icon: string; // SVG path data (d="...")
  title: string;
  description?: string;
  href: string;
  external?: boolean;
}

export interface Props {
  blocks: InfoBlock[];
  columns?: 2 | 3 | 4;
}

const { blocks, columns = 4 } = Astro.props;

const gridClass = {
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4',
}[columns];
---

<ul class={`grid ${gridClass} gap-4`} role="list">
  {blocks.map((block, i) => (
    <li>
      <a
        href={block.href}
        class={`info-block reveal reveal-delay-${(i % 4) + 1} flex flex-col items-start gap-3 rounded-2xl p-5 h-full transition-all duration-200 hover:-translate-y-1 hover:shadow-md`}
        style="background: var(--c-bg); border: 1px solid var(--c-border);"
        target={block.external ? '_blank' : undefined}
        rel={block.external ? 'noopener noreferrer' : undefined}
        aria-label={block.external ? `${block.title} (ouvre dans un nouvel onglet)` : undefined}
      >
        <div
          class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
          style="background: var(--c-primary); color: #fff;"
          aria-hidden="true"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d={block.icon} />
          </svg>
        </div>

        <div>
          <p class="text-sm font-bold" style="color: var(--c-fg);">{block.title}</p>
          {block.description && (
            <p class="text-xs mt-1 leading-relaxed" style="color: var(--c-muted);">{block.description}</p>
          )}
        </div>

        {block.external && (
          <svg class="w-3.5 h-3.5 ml-auto mt-auto flex-shrink-0" style="color: var(--c-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        )}
      </a>
    </li>
  ))}
</ul>
