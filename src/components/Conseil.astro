---
import { getCollection } from 'astro:content';

const allElus = await getCollection('elus');
allElus.sort((a, b) => a.data.ordre - b.data.ordre);

const maire = allElus.find((e) => e.data.fonction === 'Maire');
const adjoints = allElus.filter((e) =>
  ['1er Adjoint', '2ème Adjoint', '3ème Adjoint'].includes(e.data.fonction)
);
const conseillers = allElus.filter((e) =>
  ['Conseiller municipal', 'Conseillère municipale'].includes(e.data.fonction)
);

function initiales(nom: string): string {
  return nom
    .split(' ')
    .filter((w) => w.length > 1 && w === w.toUpperCase())
    .map((w) => w[0])
    .join('') || nom.slice(0, 2).toUpperCase();
}

// Palette de couleurs de fond pour les avatars (cycle)
// bg/color = light mode, bgDark/colorDark = dark mode
const palettes = [
  { bg: '#EEF2F7', color: '#2B4C6F', bgDark: '#1A2535', colorDark: '#7AAAD4' },
  { bg: '#EEF5EE', color: '#3D5E39', bgDark: '#182518', colorDark: '#7FAB78' },
  { bg: '#F7EEF2', color: '#6B3050', bgDark: '#2A1520', colorDark: '#C4849E' },
  { bg: '#EEF5EE', color: '#2D5428', bgDark: '#182218', colorDark: '#78A870' },
  { bg: '#F7F3EE', color: '#6B4A1E', bgDark: '#281E10', colorDark: '#C49A60' },
  { bg: '#EEF5F2', color: '#1E5040', bgDark: '#102018', colorDark: '#60A890' },
  { bg: '#EEF4F7', color: '#1E4A6B', bgDark: '#101E2A', colorDark: '#60A0C8' },
  { bg: '#F2EEF7', color: '#4A2E6B', bgDark: '#1E1228', colorDark: '#9878C8' },
  { bg: '#F7EEEE', color: '#6B2B2B', bgDark: '#281010', colorDark: '#C87878' },
  { bg: '#F7F0EE', color: '#6B3A1E', bgDark: '#281610', colorDark: '#C49070' },
  { bg: '#EEF6F5', color: '#1E5050', bgDark: '#102020', colorDark: '#60A8A8' },
  { bg: '#F0EEF7', color: '#3A2E6B', bgDark: '#181228', colorDark: '#8878C8' },
  { bg: '#F7EEF5', color: '#6B2058', bgDark: '#280F22', colorDark: '#C870B0' },
  { bg: '#F0F0EE', color: '#404030', bgDark: '#1E1E18', colorDark: '#A8A880' },
];
---

<section class="py-20 px-4 sm:px-6 lg:px-8" style="background: var(--c-bg);" aria-labelledby="conseil-heading">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <div class="flex items-center justify-center gap-4 mb-3">
        <div class="section-line"></div>
        <span class="section-tag">Gouvernance</span>
        <div class="section-line"></div>
      </div>
      <h2 id="conseil-heading" class="text-3xl sm:text-4xl font-black section-title">
        Conseil Municipal
      </h2>
      <p class="mt-3 max-w-xl mx-auto text-sm" style="color: var(--c-muted);">
        Mandat 2026–2032 · Liste « Kienheim, Terroir et Avenir » · {allElus.length} élus au service de la commune
      </p>
    </div>

    <!-- Maire (carte mise en avant) -->
    {maire && (
      <div class="flex justify-center mb-12 reveal">
        <article
          class="relative bg-white dark:bg-kienheim-dark-surface rounded-3xl shadow-xl p-8 flex flex-col sm:flex-row items-center gap-6 max-w-md w-full"
          style="border: 2px solid var(--c-primary);"
          aria-labelledby="maire-name"
        >
          <!-- Badge -->
          <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
            <span class="px-4 py-1 rounded-full text-xs font-bold text-white" style="background: var(--c-primary);">
              Maire
            </span>
          </div>

          <!-- Avatar ou photo -->
          {maire.data.photo ? (
            <img
              src={maire.data.photo}
              alt={`Photo de ${maire.data.nom}`}
              class="flex-shrink-0 w-24 h-24 rounded-full object-cover shadow-lg"
            />
          ) : (
            <div
              class="flex-shrink-0 w-24 h-24 rounded-full flex items-center justify-center shadow-lg"
              style="background: linear-gradient(135deg, #2B4C6F 0%, #5B8AB5 100%);"
              aria-hidden="true"
            >
              <svg class="w-14 h-14 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
              </svg>
            </div>
          )}

          <!-- Infos -->
          <div class="text-center sm:text-left">
            <h3 id="maire-name" class="text-xl font-black" style="color: var(--c-fg);">{maire.data.nom}</h3>
            <p class="font-semibold mt-0.5" style="color: var(--c-primary);">{maire.data.fonction}</p>
            {maire.data.commission && (
              <p class="text-xs mt-0.5" style="color: var(--c-muted);">{maire.data.commission}</p>
            )}
            <p class="text-xs mt-1" style="color: var(--c-muted);">Liste « Kienheim, Terroir et Avenir » — Élu en 2026</p>
            <a href="mailto:maire@kienheim.fr" class="btn-accent mt-3 inline-flex">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Contacter
            </a>
          </div>
        </article>
      </div>
    )}

    <!-- Adjoints -->
    {adjoints.length > 0 && (
      <div class="mb-10">
        <h3 class="text-center text-sm font-semibold uppercase tracking-widest mb-6" style="color: var(--c-muted);">
          Adjoints
        </h3>
        <ul class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto" role="list">
          {adjoints.map((elu, i) => {
            const p = palettes[i % palettes.length];
            return (
              <li>
                <article
                  class={`reveal reveal-delay-${(i % 3) + 1} rounded-2xl p-4 text-center shadow-sm hover:-translate-y-1 hover:shadow-md transition-all duration-200 bg-white dark:bg-kienheim-dark-surface`}
                  style="border: 1px solid var(--c-border);"
                  aria-labelledby={`adjoint-${elu.slug}`}
                >
                  {elu.data.photo ? (
                    <img
                      src={elu.data.photo}
                      alt={`Photo de ${elu.data.nom}`}
                      class="w-12 h-12 rounded-full object-cover mx-auto mb-2"
                    />
                  ) : (
                    <div
                      class="avatar-initiales w-12 h-12 rounded-full flex items-center justify-center font-bold text-sm mx-auto mb-2"
                      style={`background: ${p.bg}; color: ${p.color};`}
                      data-bg-dark={p.bgDark}
                      data-color-dark={p.colorDark}
                      aria-hidden="true"
                    >
                      {initiales(elu.data.nom)}
                    </div>
                  )}
                  <h4 id={`adjoint-${elu.slug}`} class="text-xs font-bold leading-tight" style="color: var(--c-fg);">{elu.data.nom}</h4>
                  <p class="text-xs mt-0.5 leading-tight" style="color: var(--c-muted);">{elu.data.fonction}</p>
                  {elu.data.commission && (
                    <p class="text-xs mt-0.5 leading-tight" style="color: var(--c-secondary);">{elu.data.commission}</p>
                  )}
                </article>
              </li>
            );
          })}
        </ul>
      </div>
    )}

    <!-- Conseillers municipaux -->
    {conseillers.length > 0 && (
      <div>
        <h3 class="text-center text-sm font-semibold uppercase tracking-widest mb-6" style="color: var(--c-muted);">
          Conseillers municipaux
        </h3>
        <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-7 gap-4" role="list">
          {conseillers.map((elu, i) => {
            const p = palettes[(adjoints.length + i) % palettes.length];
            return (
              <li>
                <article
                  class={`reveal reveal-delay-${(i % 4) + 1} rounded-2xl p-4 text-center shadow-sm hover:-translate-y-1 hover:shadow-md transition-all duration-200 bg-white dark:bg-kienheim-dark-surface`}
                  style="border: 1px solid var(--c-border);"
                  aria-labelledby={`conseiller-${elu.slug}`}
                >
                  {elu.data.photo ? (
                    <img
                      src={elu.data.photo}
                      alt={`Photo de ${elu.data.nom}`}
                      class="w-12 h-12 rounded-full object-cover mx-auto mb-2"
                    />
                  ) : (
                    <div
                      class="avatar-initiales w-12 h-12 rounded-full flex items-center justify-center font-bold text-sm mx-auto mb-2"
                      style={`background: ${p.bg}; color: ${p.color};`}
                      data-bg-dark={p.bgDark}
                      data-color-dark={p.colorDark}
                      aria-hidden="true"
                    >
                      {initiales(elu.data.nom)}
                    </div>
                  )}
                  <h4 id={`conseiller-${elu.slug}`} class="text-xs font-bold leading-tight" style="color: var(--c-fg);">{elu.data.nom}</h4>
                  <p class="text-xs mt-0.5 leading-tight" style="color: var(--c-muted);">{elu.data.fonction}</p>
                  {elu.data.commission && (
                    <p class="text-xs mt-0.5 leading-tight" style="color: var(--c-secondary);">{elu.data.commission}</p>
                  )}
                </article>
              </li>
            );
          })}
        </ul>
      </div>
    )}

  </div>
</section>

<script>
  function applyAvatarDark() {
    const isDark = document.documentElement.classList.contains('dark') ||
      window.matchMedia('(prefers-color-scheme: dark)').matches;
    document.querySelectorAll<HTMLElement>('.avatar-initiales').forEach((el) => {
      if (isDark) {
        el.style.background = el.dataset.bgDark || el.style.background;
        el.style.color = el.dataset.colorDark || el.style.color;
      } else {
        el.style.background = el.dataset.bgLight || el.style.background;
        el.style.color = el.dataset.colorLight || el.style.color;
      }
    });
  }
  // Mémorise les valeurs light au premier chargement
  document.querySelectorAll<HTMLElement>('.avatar-initiales').forEach((el) => {
    el.dataset.bgLight = el.style.background;
    el.dataset.colorLight = el.style.color;
  });
  applyAvatarDark();
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', applyAvatarDark);
  new MutationObserver(applyAvatarDark).observe(document.documentElement, {
    attributes: true, attributeFilter: ['class'],
  });
</script>
