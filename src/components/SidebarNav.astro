---
export interface NavSection {
  id: string;
  label: string;
  icon?: string; // SVG path d="..."
}

export interface Props {
  sections: NavSection[];
}

const { sections } = Astro.props;
---

<!-- Mobile: accordéon en haut de page -->
<div class="lg:hidden sticky top-16 z-40 px-4 pt-3 pb-1" style="background: var(--c-bg); border-bottom: 1px solid var(--c-border);">
  <button
    id="sidebar-mobile-toggle"
    class="flex items-center justify-between w-full px-4 py-2.5 rounded-xl text-sm font-semibold"
    style="background: var(--c-primary); color: #fff;"
    aria-expanded="false"
    aria-controls="sidebar-mobile-menu"
  >
    <span id="sidebar-current-label">{sections[0]?.label ?? 'Navigation'}</span>
    <svg id="sidebar-chevron" class="w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  <div
    id="sidebar-mobile-menu"
    class="overflow-hidden transition-all duration-300"
    style="max-height: 0;"
    role="menu"
  >
    <ul class="py-2 space-y-1">
      {sections.map((s) => (
        <li>
          <a
            href={`#${s.id}`}
            class="sidebar-link-mobile flex items-center gap-2 px-4 py-2.5 text-sm rounded-xl transition-colors"
            style="color: var(--c-fg);"
            role="menuitem"
            data-section={s.id}
          >
            {s.icon && (
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={s.icon} />
              </svg>
            )}
            {s.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</div>

<!-- Desktop: sidebar sticky -->
<aside
  class="hidden lg:block sticky top-20 self-start w-56 flex-shrink-0"
  aria-label="Navigation de la page"
>
  <nav>
    <ul class="space-y-1" role="list">
      {sections.map((s) => (
        <li>
          <a
            href={`#${s.id}`}
            class="sidebar-link flex items-center gap-2.5 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200"
            style="color: var(--c-muted);"
            data-section={s.id}
            aria-current="false"
          >
            {s.icon && (
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={s.icon} />
              </svg>
            )}
            {s.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
  .sidebar-link.active {
    background: color-mix(in srgb, var(--c-primary) 12%, transparent);
    color: var(--c-primary);
    font-weight: 700;
  }
  .sidebar-link-mobile.active {
    background: color-mix(in srgb, var(--c-primary) 12%, transparent);
    color: var(--c-primary);
    font-weight: 700;
  }
</style>

<script>
  // Scroll-spy desktop
  const links = document.querySelectorAll<HTMLAnchorElement>('.sidebar-link');
  const mobileLinks = document.querySelectorAll<HTMLAnchorElement>('.sidebar-link-mobile');
  const currentLabel = document.getElementById('sidebar-current-label');

  const sectionIds = Array.from(links).map((l) => l.dataset.section!).filter(Boolean);
  const sections = sectionIds.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];

  function setActive(id: string) {
    links.forEach((l) => {
      const active = l.dataset.section === id;
      l.classList.toggle('active', active);
      l.setAttribute('aria-current', active ? 'true' : 'false');
    });
    mobileLinks.forEach((l) => {
      l.classList.toggle('active', l.dataset.section === id);
    });
    const activeLink = Array.from(links).find((l) => l.dataset.section === id);
    if (currentLabel && activeLink) {
      currentLabel.textContent = activeLink.textContent?.trim() ?? '';
    }
  }

  const spy = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
        }
      });
    },
    { rootMargin: '-20% 0px -60% 0px' }
  );
  sections.forEach((s) => spy.observe(s));
  if (sections.length) setActive(sections[0].id);

  // Smooth scroll on link click
  [...links, ...mobileLinks].forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const id = link.dataset.section!;
      const target = document.getElementById(id);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      // Close mobile menu
      const menu = document.getElementById('sidebar-mobile-menu');
      const toggle = document.getElementById('sidebar-mobile-toggle');
      const chevron = document.getElementById('sidebar-chevron');
      if (menu && toggle && chevron) {
        (menu as HTMLElement).style.maxHeight = '0';
        toggle.setAttribute('aria-expanded', 'false');
        chevron.style.transform = '';
      }
    });
  });

  // Mobile toggle
  const toggle = document.getElementById('sidebar-mobile-toggle');
  const mobileMenu = document.getElementById('sidebar-mobile-menu');
  const chevron = document.getElementById('sidebar-chevron');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    if (mobileMenu) {
      (mobileMenu as HTMLElement).style.maxHeight = expanded ? '0' : '400px';
    }
    if (chevron) {
      chevron.style.transform = expanded ? '' : 'rotate(180deg)';
    }
  });
</script>
