---
---

<section
  id="accueil"
  class="relative h-screen min-h-[600px] flex flex-col items-center justify-center overflow-hidden"
  aria-label="Bienvenue à Kienheim"
>
  <!-- Video background -->
  <video
    class="absolute inset-0 w-full h-full object-cover"
    autoplay
    muted
    loop
    playsinline
    aria-hidden="true"
    poster="/assets/images/blason.png"
  >
    <source src="/assets/video/hero.mp4" type="video/mp4" />
  </video>

  <!-- Gradient overlay : primary/80 en bas → transparent en haut -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: linear-gradient(to top, rgba(43,76,111,0.88) 0%, rgba(43,76,111,0.50) 35%, rgba(43,76,111,0.18) 65%, transparent 100%);"
  ></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center text-center px-4 gap-4 sm:gap-6">
    <!-- Blason -->
    <div class="hero-anim-1">
      <img
        src="/assets/images/blason.png"
        alt="Blason officiel de la commune de Kienheim"
        class="w-20 h-20 sm:w-28 sm:h-28 md:w-36 md:h-36 object-contain drop-shadow-2xl"
      />
    </div>

    <!-- Titre principal -->
    <h1
      class="hero-anim-2 text-white font-black tracking-[0.25em] uppercase leading-none drop-shadow-2xl"
      style="font-size: clamp(3.5rem, 11vw, 9rem); font-variation-settings: 'wght' 900;"
    >
      KIENHEIM
    </h1>

    <!-- Sous-titre -->
    <p
      class="hero-anim-3 text-white/85 italic font-light tracking-widest drop-shadow-md"
      style="font-size: clamp(1rem, 2.5vw, 1.5rem);"
    >
      Au cœur du Kochersberg
    </p>

    <!-- CTA -->
    <a
      href="#apercu"
      class="hero-anim-4 mt-2 px-6 py-2.5 text-sm font-semibold rounded-full transition-all duration-300 backdrop-blur-sm"
      style="border: 1.5px solid rgba(201,168,76,0.6); color: #fff; background: rgba(201,168,76,0.15);"
      onmouseover="this.style.background='rgba(201,168,76,0.30)'; this.style.borderColor='rgba(201,168,76,0.9)';"
      onmouseout="this.style.background='rgba(201,168,76,0.15)'; this.style.borderColor='rgba(201,168,76,0.6)';"
    >
      Découvrir le village
    </a>
  </div>

  <!-- Scroll arrow -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2" aria-hidden="true">
    <span class="text-white/60 text-xs tracking-widest uppercase">Défiler</span>
    <a href="#apercu" aria-label="Aller à la section suivante" class="text-white/70 hover:text-white transition bounce-arrow block">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </div>
</section>
